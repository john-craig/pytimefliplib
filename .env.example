# Copy to .env and fill in values for local physical-device testing.
# .env is ignored by git.
TIMEFLIP_ADDRESS=AA:BB:CC:DD:EE:FF
TIMEFLIP_ADAPTER=hci0
TIMEFLIP_PASSWORD=000000

# Optional: discover by advertised name if TIMEFLIP_ADDRESS is omitted.
# TIMEFLIP_NAME=TimeFlip

# Optional collection knobs.
TIMEFLIP_SCAN_TIMEOUT=20
TIMEFLIP_NOTIFY_SECONDS=0
TIMEFLIP_READ_HISTORY=false
